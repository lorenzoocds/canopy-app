VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# DoorDash Drive (server-side only — used by Edge Functions)
DOORDASH_DEVELOPER_ID=your-developer-id
DOORDASH_KEY_ID=your-key-id
DOORDASH_SIGNING_SECRET=your-signing-secret
DOORDASH_ENV=sandbox

# Dispatch provider (doordash or uber)
DISPATCH_PROVIDER=doordash
